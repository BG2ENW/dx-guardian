# Flask runtime
FLASK_ENV=development
DEBUG=true
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# Application secret
SECRET_KEY=replace-with-a-long-random-secret

# Wavelog integration
WAVELOG_URL=https://example.com
WAVELOG_API_KEY=replace-with-wavelog-api-key

# ClubLog callbook
CLUBLOG_APP_PASSWORD=replace-with-clublog-app-password

# QRZ lookup
QRZ_USERNAME=replace-with-qrz-username
QRZ_PASSWORD=replace-with-qrz-password

# HamQTH lookup
HAMQTH_USERNAME=replace-with-hamqth-username
HAMQTH_PASSWORD=replace-with-hamqth-password

# Web Push (VAPID)
# Keep PEM as a single line with escaped newlines: \n
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n
VAPID_EMAIL=mailto:replace-with-your-email@example.com
