# DX Guardian 环境变量配置

# ===== 第三方 API 配置 =====

# QRZ.com API Key（需要付费订阅 XML 数据）
# 获取方式：https://www.qrz.com/XML/subscriber_info.htm
QRZ_API_KEY=your_qrz_api_key_here

# HamQTH.com API Key（免费）
# 获取方式：https://www.hamqth.com/xml_api.php
HAMQTH_API_KEY=your_hamqth_api_key_here

# ===== Wavelog 集成配置 =====

# Wavelog 实例 URL (如 https://cqcqcq.com.cn/)
WAVELOG_URL=https://cqcqcq.com.cn/

# Wavelog API 密钥 (在 Wavelog 设置中生成)
WAVELOG_API_KEY=your_wavelog_api_key_here

# Wavelog 数据库直连配置（仅内部使用，用于 LoTW 等功能）
# 注意：生产环境必须配置，开发环境可使用默认值
WAVELOG_DB_HOST=39.103.65.85
WAVELOG_DB_PORT=3306
WAVELOG_DB_USER=wavelog
WAVELOG_DB_PASSWORD=your_wavelog_db_password_here
WAVELOG_DB_DATABASE=wavelog

# ===== Web Push 配置 =====

# VAPID 密钥 (使用 web-push 或 py-vapid 生成)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY_PEM=your_vapid_private_key_here
VAPID_EMAIL=your_email@example.com

# ===== 其他配置 =====

# Flask 密钥（生产环境必须）
SECRET_KEY=your_secret_key_here

# 调试模式（生产环境设为 False）
DEBUG=True
