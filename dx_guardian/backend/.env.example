# DX Guardian 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# Flask 配置
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-flask-secret-key-here
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# Wavelog 集成配置
WAVELOG_URL=https://your-wavelog-instance.com/
WAVELOG_API_KEY=your_wavelog_api_key_here
WAVELOG_STATION_CALLSIGN=

# ClubLog Application Password（用于 callbook 查询）
# 获取方式：登录 ClubLog -> Settings -> App Passwords
CLUBLOG_APP_PASSWORD=your_clublog_password

# QRZ.com XML API 配置（用于呼号 Grid 查询）
QRZ_USERNAME=your_qrz_username
QRZ_PASSWORD=your_qrz_password

# HamQTH API 配置（备用呼号 Grid 查询）
HAMQTH_USERNAME=your_hamqth_username
HAMQTH_PASSWORD=your_hamqth_password

# Web Push (VAPID) - 使用 python-pushnotifications 生成
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY_PEM=your_vapid_private_key
VAPID_EMAIL=mailto:your-email@example.com